# Copy this file to .env.local for local dev, or set these in Vercel's
# Environment Variables settings for production.

# --- Airtable PATs (1.2: scoped per-base tokens) ---
# Six PATs replacing the single AIRTABLE_TOKEN. Each is scoped to one base so
# a leak (or rotation) only affects that base. Helpers fall back to the legacy
# AIRTABLE_TOKEN below if the scoped name is unset — remove the fallback once
# `git grep AIRTABLE_TOKEN lib/ scripts/` returns clean.
#
# Mint each at https://airtable.com/create/tokens and pin the listed base.
AIRTABLE_PAT_CLEARANCE=pat_xxxxxxxxxxxxxxxx       # data.records:read+write on appRMQ2om6bffGVBS (Clearance)
AIRTABLE_PAT_PRODUCTS=pat_xxxxxxxxxxxxxxxx        # data.records:read+write on appZuFJJTEf7TL0IQ (Products Master) — admin can edit products via /catalog/manage
AIRTABLE_PAT_PAPER_RM=pat_xxxxxxxxxxxxxxxx        # data.records:read+write on appSllndIZszJSCma (Paper RM) — admin patches Base Rate / Discount via /factoryos/admin/master-papers
AIRTABLE_PAT_ORDERS=pat_xxxxxxxxxxxxxxxx          # data.records:read+write on appDEhKCVRAsYjSX2 (Orders / FactoryOS); add schema.bases:read+write if you run scripts/provision-orders-schema.js
AIRTABLE_PAT_HR=pat_xxxxxxxxxxxxxxxx              # placeholder — wired up in 1.3 when HR tables move out of Orders. Mint with empty scope for now (or skip until then).
AIRTABLE_PAT_CALCULATOR=pat_xxxxxxxxxxxxxxxx      # data.records:read+write on appWO53wnIZKdKRlq (Calculator) — catalog calc + rate-cards + legacy paper-bag-calculator app

# Legacy single-base PAT — DEPRECATED, remove after 1.2 cutover.
# Helpers fall back to this if a scoped PAT above is unset, so production keeps
# working through the migration. Once Vercel envs hold all six scoped PATs and
# `git grep AIRTABLE_TOKEN lib/ scripts/` is clean, drop this line.
AIRTABLE_TOKEN=pat_xxxxxxxxxxxxxxxx

# Airtable base ID (pre-filled for Aeros Clearance Stock)
AIRTABLE_BASE_ID=appRMQ2om6bffGVBS

# Airtable table ID (pre-filled for Plain Items)
AIRTABLE_TABLE_ID=tblFJjqMIQhByuLHv

# Optional: specific view name to fetch from (e.g., "Public Catalog")
# Leave blank to fetch all records from the table
AIRTABLE_VIEW=

# --- Paper Bag Rate Calculator ---
# Reuses AIRTABLE_TOKEN above (same Airtable account, different base)
AIRTABLE_CALC_BASE_ID=appWO53wnIZKdKRlq
AIRTABLE_BAG_SPECS_TABLE=Bag Specs
AIRTABLE_QUOTES_TABLE=Quotes
AIRTABLE_BOX_QUOTES_TABLE=Box Quotes
AIRTABLE_CLIENTS_TABLE=Clients
AIRTABLE_OTP_TABLE=OTP Codes

# Paper RM master catalogue (read-only, shared across Aeros apps)
AIRTABLE_PAPER_RM_BASE_ID=appSllndIZszJSCma

# Fallback paper rate (₹/kg) used for client-side box quotes until per-paper rates wire up
DEFAULT_BOX_PAPER_RATE=70

# Master password for admin login on /calculator
ADMIN_PASSWORD=change-me

# HMAC secret for signing session cookies. `openssl rand -base64 32`.
SESSION_SECRET=replace-with-random-32-char-string

# Resend for OTP email delivery
RESEND_API_KEY=re_xxx
OTP_FROM_EMAIL=Aeros <noreply@yourdomain.com>

DEFAULT_CLIENT_MARGIN=15

# --- FactoryOS module ---
# Airtable base for FactoryOS (jobs, HR, RM inventory, etc.). Reuses
# AIRTABLE_TOKEN. The app also falls back to the legacy AIRTABLE_ORDERS_*
# names so you can migrate env vars at your own pace.
AIRTABLE_FACTORYOS_BASE_ID=appDEhKCVRAsYjSX2

# Table names (defaults shown — override only if you named them differently)
AIRTABLE_FACTORYOS_CLIENTS_TABLE=Clients
AIRTABLE_FACTORYOS_USERS_TABLE=Users
AIRTABLE_FACTORYOS_JOBS_TABLE=Jobs
AIRTABLE_FACTORYOS_UPDATES_TABLE=Job Status Updates
AIRTABLE_FACTORYOS_OTP_TABLE=OTP Codes

# --- PackAI restricted DB access (M0) ---
# The public AI module reads ONLY the sanitized v_packai_* views, as the
# packai_ro Postgres role. The JWT is minted at runtime from this secret:
# Supabase Dashboard → Settings → API → JWT Secret. Required alongside
# SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY.
SUPABASE_JWT_SECRET=
